rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net & Helpers
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Project Helpers
    // -------------------------------------------------------------------------
    function canAccessProject(projectId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    // -------------------------------------------------------------------------
    // Entity Validations
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200;
    }

    function isValidUniverse(data) {
      return data.keys().hasAll(['title', 'ownerId', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 8 &&
             data.title is string && data.title.size() <= 200 &&
             data.ownerId == request.auth.uid;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'type', 'ownerId', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 16 &&
             data.title is string && data.title.size() <= 200 &&
             (!data.keys().hasAny(['subtitle']) || (data.subtitle is string && data.subtitle.size() <= 300)) &&
             data.type in ['novel', 'manga', 'script', 'comic', 'rpg', 'lore'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidStoryItem(data) {
      return data.keys().hasAll(['name', 'type', 'updatedAt']) &&
             data.keys().size() <= 12 &&
             data.name is string && data.name.size() <= 200 &&
             data.type in ['item', 'magic', 'function', 'location', 'lore'];
    }

    function isValidCharacter(data) {
      return data.keys().hasAll(['name', 'updatedAt']) &&
             data.keys().size() <= 15 &&
             data.name is string && data.name.size() <= 100;
    }

    function isValidArtAsset(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'type', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.title is string && data.title.size() <= 200 &&
             data.imageUrl is string && data.imageUrl.size() <= 2000 &&
             data.type in ['concept', 'panel', 'background'];
    }

    function isValidLore(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.category in ['world', 'lore', 'note', 'rpg', 'item', 'magic', 'faction', 'timeline'];
    }

    function isValidLoreVersion(data) {
      return data.keys().hasAll(['content', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.content is string && data.content.size() <= 100000 &&
             (!data.keys().hasAny(['note']) || (data.note is string && data.note.size() <= 500));
    }

    function isValidVersion(data) {
      return data.keys().hasAll(['content', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.content is string && data.content.size() <= 100000;
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['goal', 'deadline', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.goal is number &&
             data.deadline is timestamp;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['role', 'text', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.role in ['user', 'assistant'] &&
             data.text is string && data.text.size() <= 10000;
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['title', 'content', 'order', 'updatedAt', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 500000 &&
             data.order is number;
    }

    function isValidCinematicNode(data) {
      return data.keys().hasAll(['type', 'x', 'y', 'width', 'height', 'content', 'order', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.type in ['panel', 'scene', 'text', 'ref'] &&
             data.x is number && data.y is number &&
             data.width is number && data.height is number &&
             data.order is number;
    }

    // -------------------------------------------------------------------------
    // Match Blocks
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
      );
    }

    match /universes/{universeId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isOwner(existing().ownerId);
      allow create: if isSignedIn() && isValidId(universeId) && isValidUniverse(incoming()) && 
                       incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isOwner(existing().ownerId) && isValidUniverse(incoming()) && 
                       incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'updatedAt'])
      );
      allow delete: if isOwner(existing().ownerId);
    }

    match /projects/{projectId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isOwner(existing().ownerId);
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) && 
                       incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isOwner(existing().ownerId) && isValidProject(incoming()) && 
                       incoming().updatedAt == request.time && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'subtitle', 'description', 'currentContent', 'genre', 'updatedAt'])
      );
      allow delete: if isOwner(existing().ownerId);

      // Sub-collections
      match /art/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidArtAsset(incoming()) && incoming().createdAt == request.time;
        allow delete: if canAccessProject(projectId);
      }

      match /characters/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidCharacter(incoming()) && incoming().updatedAt == request.time;
        allow update: if canAccessProject(projectId) && isValidCharacter(incoming()) && incoming().updatedAt == request.time && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'role', 'traits', 'isAutoDetected', 'updatedAt'])
        );
        allow delete: if canAccessProject(projectId);
      }

      match /lore/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidLore(incoming()) && incoming().updatedAt == request.time;
        allow update: if canAccessProject(projectId) && isValidLore(incoming()) && incoming().updatedAt == request.time && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'updatedAt', 'properties'])
        );
        allow delete: if canAccessProject(projectId);

        match /versions/{vId} {
          allow list: if canAccessProject(projectId);
          allow get: if canAccessProject(projectId);
          allow create: if canAccessProject(projectId) && isValidLoreVersion(incoming()) && incoming().createdAt == request.time;
          allow delete: if canAccessProject(projectId);
        }
      }

      match /items/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidStoryItem(incoming()) && incoming().updatedAt == request.time;
        allow update: if canAccessProject(projectId) && isValidStoryItem(incoming()) && incoming().updatedAt == request.time && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'type', 'properties', 'imageUrl', 'updatedAt'])
        );
        allow delete: if canAccessProject(projectId);
      }

      match /versions/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidVersion(incoming()) && incoming().createdAt == request.time;
        allow delete: if canAccessProject(projectId);
      }

      match /schedules/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidSchedule(incoming()) && incoming().updatedAt == request.time;
        allow update: if canAccessProject(projectId) && isValidSchedule(incoming()) && incoming().updatedAt == request.time && (
          incoming().diff(existing()).affectedKeys().hasOnly(['goal', 'deadline', 'currentProgress', 'title', 'updatedAt'])
        );
        allow delete: if canAccessProject(projectId);
      }

      match /chat/{id} {
        allow list: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidChatMessage(incoming()) && incoming().createdAt == request.time;
      }

      match /chapters/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidChapter(incoming()) && 
                         incoming().createdAt == request.time && incoming().updatedAt == request.time;
        allow update: if canAccessProject(projectId) && isValidChapter(incoming()) && 
                         incoming().updatedAt == request.time && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'order', 'updatedAt'])
        );
        allow delete: if canAccessProject(projectId);
      }

      match /cinematic/{id} {
        allow list: if canAccessProject(projectId);
        allow get: if canAccessProject(projectId);
        allow create: if canAccessProject(projectId) && isValidCinematicNode(incoming()) && incoming().createdAt == request.time;
        allow update: if canAccessProject(projectId) && isValidCinematicNode(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['x', 'y', 'width', 'height', 'content', 'order'])
        );
        allow delete: if canAccessProject(projectId);
      }
    }
  }
}
