rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar se o usuário é dono do documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Regras para Projetos
    match /projects/{projectId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if request.auth != null;

      // Subcoleções (chapters, lore, art, cinematic, chat, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId);
      }
    }

    // Regras para Universos
    match /universes/{universeId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if request.auth != null;
    }
  }
}