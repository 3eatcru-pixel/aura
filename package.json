{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:rules": "npx firebase emulators:exec --only firestore \"mocha tests/**/*.test.cjs --exit\""
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.73",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "ai": "^6.0.182",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fabric": "^7.3.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^11.10.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "motion-dom": "^12.38.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^2.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/fabric": "^5.3.11",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "chai": "^4.3.8",
    "esbuild": "^0.28.0",
    "firebase-tools": "^15.18.0",
    "mocha": "^10.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
